# Kronaxis Panel Studio - Environment Configuration
# Copy this file to .env and fill in the required values.
# https://kronaxis.co.uk | contact@kronaxis.co.uk

# =============================================================================
# MANDATORY
# =============================================================================

# PostgreSQL password. Must match the db service.
TFS_DB_PASSWORD=

# Flask session secret. Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# =============================================================================
# LLM
# =============================================================================

# LLM server endpoint URL. Default points to the Ollama container in docker-compose.
# OLLAMA_URL=http://kps-ollama:11434

# Model for persona responses and panel builder. Pulled automatically on first boot.
# Use any model compatible with your LLM server (e.g. a 4B parameter instruction model).
OLLAMA_MODEL=qwen2.5:3b

# Optional: separate model for persona building (larger model = higher quality personas).
# OLLAMA_BUILD_MODEL=

# =============================================================================
# OPTIONAL
# =============================================================================

# Enable session-based authentication and multi-tenancy.
# PANEL_STUDIO_AUTH=false

# Enable email-gated features (panel builder, exports).
# Set to false for local development. Default: true.
# KRONAXIS_GATE_ENABLED=true

# Kronaxis API key validation endpoint. Keys validated via POST ?validate with JSON body {"key": "kx_..."}.
# Returns {"valid": true/false}. Results cached for 5 minutes.
# KRONAXIS_REGISTER_URL=https://kronaxis.co.uk/register
